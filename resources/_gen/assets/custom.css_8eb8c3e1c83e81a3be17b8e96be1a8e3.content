@charset "UTF-8";:root{--color-main:#F37F2D;--color-secondary:#273B48;--color-green:#A0B882;--color-yellow:#ECC35C;--color-blue:#619B8A}*{margin:0;padding:0;box-sizing:border-box}body{font-family:system-ui,-apple-system,BlinkMacSystemFont,segoe ui,sans-serif;color:var(--color-secondary);line-height:1.6;background:url(/images/logos/logo-white.png)repeat;background-size:50px 50px;background-color:#f3f1f1}.container{max-width:1200px;margin:0 auto;padding:0 1rem}.hero-section{background-color:var(--color-main);color:#fff;padding:1rem 0;text-align:center}.header-content{display:flex;flex-direction:column;align-items:center;gap:1rem}.header-logo{max-height:120px;width:auto}.nav-links ul{display:flex;justify-content:center;list-style:none;gap:2rem}.nav-links a{color:#fff;text-decoration:none;font-weight:700}.nav-links a:hover{text-decoration:underline}.title-section{text-align:center;padding:4rem 1rem}.title-section h1{font-size:2.5rem;color:var(--color-secondary);margin-bottom:1rem}.title-section p{font-size:1.2rem;color:#666}.logos-section{padding:3rem 1rem;background-color:#f5f5f5;text-align:center}.logos img{width:100px;height:100px;object-fit:contain;margin:1rem;display:inline-block}footer{background-color:var(--color-secondary);color:#fff;padding:1rem 0;text-align:center}footer .footer-logo{max-height:40px;margin-bottom:10px}